# Copiá este archivo a .env.local (nunca lo subas a git)
# Vite solo expone variables con prefijo VITE_

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Opcional: si no usás el proxy de Vite en desarrollo
# VITE_API_BASE_URL=http://127.0.0.1:8787

# Producción: URL pública exacta de tu frontend (sin barra final)
# Debe estar también en Supabase → Authentication → URL Configuration → Redirect URLs
# VITE_APP_URL=https://tu-app.vercel.app
