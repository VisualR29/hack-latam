# ========================================
# VARIABLES DE ENTORNO - SUPABASE
# ========================================
# Copia este archivo a .env.local (frontend) o .env (backend)
# y llena los valores de tu proyecto Supabase

# ========================================
# FRONTEND (.env en client/)
# ========================================

# URL del proyecto Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co

# Clave pública anon (segura para el cliente)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Opcional: URL del servidor backend (si aplica)
VITE_API_URL=http://localhost:3000

# ========================================
# BACKEND (.env en server/)
# ========================================

# URL del proyecto Supabase
SUPABASE_URL=https://your-project.supabase.co

# Clave pública anon
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave privada service_role (NUNCA compartir, solo en servidor)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Puerto del servidor
PORT=3000

# Ambiente
NODE_ENV=development

# ========================================
# CÓMO OBTENER ESTOS VALORES
# ========================================

# 1. Ve a supabase.com y crea una cuenta
# 2. Crea un nuevo proyecto
# 3. Ve a Project Settings → API
# 4. Copia:
#    - Project URL → SUPABASE_URL
#    - anon (public) key → SUPABASE_ANON_KEY / VITE_SUPABASE_ANON_KEY
#    - service_role key → SUPABASE_SERVICE_KEY (servidor solamente)

# ========================================
# OAUTH GITHUB (Opcional)
# ========================================

# Si necesitas GitHub OAuth, genera credenciales en:
# GitHub Settings → Developer settings → OAuth Apps → New OAuth App

GITHUB_OAUTH_CLIENT_ID=your_github_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret
